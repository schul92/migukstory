---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { CATEGORIES } from '../../content.config';

export async function getStaticPaths() {
	const all = await getCollection('blog');
	return Object.entries(CATEGORIES).map(([key, meta]) => ({
		params: { slug: meta.slug },
		props: {
			catKey: key,
			catMeta: meta,
			posts: all
				.filter(p => p.data.category === key)
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { catMeta, posts } = Astro.props;
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead
			title={`${catMeta.label} — ${SITE_TITLE}`}
			description={`미국 스토리의 ${catMeta.label} 관련 기사 모음. 정부와 주요 언론의 1차 출처를 바탕으로 정리합니다.`}
			breadcrumbs={[
				{ name: '홈', url: '/' },
				{ name: catMeta.label, url: `/category/${catMeta.slug}` },
			]}
		/>
	</head>
	<body>
		<Header />
		<main>
			<div class="container">
				<header class="cat-head" style={`--cat: ${catMeta.color}`}>
					<p class="eyebrow">CATEGORY · 카테고리</p>
					<h1>{catMeta.label}</h1>
					<p class="cat-sub">관련 기사 {posts.length}편</p>
				</header>

				{posts.length === 0 ? (
					<p class="empty">아직 이 카테고리의 글이 없습니다. 곧 업데이트됩니다.</p>
				) : (
					<>
						<!-- Sort + search filter -->
						<div class="cat-filters">
							<div class="sort-group">
								<label for="sort-select" class="filter-label">정렬</label>
								<select id="sort-select">
									<option value="newest">최신순</option>
									<option value="oldest">오래된순</option>
									<option value="title">제목순</option>
								</select>
							</div>
							<div class="search-group">
								<label for="search-input" class="sr-only">검색</label>
								<input id="search-input" type="search" placeholder="제목·설명·태그 검색..." autocomplete="off" />
							</div>
							<span class="visible-count"><span id="visible-count">{posts.length}</span>편 표시</span>
						</div>

						<ol class="list" id="cat-list">
							{posts.map((post, i) => (
								<li
									class="archive-item"
									data-title={post.data.title.toLowerCase()}
									data-desc={post.data.description.toLowerCase()}
									data-tags={(post.data.tags || []).join('|')}
									data-date={post.data.pubDate.toISOString()}
								>
									<div class="num">{String(posts.length - i).padStart(2, '0')}</div>
									<a href={`/blog/${post.id}/`} class="card">
										<h2>{post.data.title}</h2>
										<p>{post.data.description}</p>
										<div class="meta">
											<FormattedDate date={post.data.pubDate} />
											{post.data.tags.slice(0, 3).map((t: string) => <span class="tag">#{t}</span>)}
										</div>
									</a>
								</li>
							))}
						</ol>
						<p class="empty-filter" id="empty-filter" hidden>일치하는 글이 없습니다.</p>
					</>
				)}

				<script is:inline>
					(function () {
						const list = document.getElementById('cat-list');
						if (!list) return;
						const items = Array.from(list.querySelectorAll('.archive-item'));
						const visibleCount = document.getElementById('visible-count');
						const sortSelect = document.getElementById('sort-select');
						const searchInput = document.getElementById('search-input');
						const emptyMsg = document.getElementById('empty-filter');

						function applyFilter() {
							const q = searchInput.value.trim().toLowerCase();
							let visible = 0;
							items.forEach(it => {
								const show = !q ||
									it.dataset.title.includes(q) ||
									it.dataset.desc.includes(q) ||
									it.dataset.tags.toLowerCase().includes(q);
								it.style.display = show ? '' : 'none';
								if (show) visible++;
							});
							visibleCount.textContent = visible;
							emptyMsg.hidden = visible !== 0;
						}

						function applySort() {
							const mode = sortSelect.value;
							const sorted = [...items].sort((a, b) => {
								if (mode === 'newest') return b.dataset.date.localeCompare(a.dataset.date);
								if (mode === 'oldest') return a.dataset.date.localeCompare(b.dataset.date);
								if (mode === 'title')  return a.dataset.title.localeCompare(b.dataset.title, 'ko');
								return 0;
							});
							sorted.forEach(it => list.appendChild(it));
						}

						searchInput.addEventListener('input', applyFilter);
						sortSelect.addEventListener('change', applySort);
					})();
				</script>
			</div>
		</main>
		<Footer />
		<style>
			.cat-head {
				text-align: center;
				padding: var(--s-6) 0 var(--s-3);
				border-bottom: 3px solid var(--cat, var(--ink));
				margin-bottom: var(--s-5);
			}
			.eyebrow { color: var(--cat, var(--brick)) !important; margin: 0 0 var(--s-2); }
			.cat-head h1 {
				font-family: var(--font-display);
				font-size: clamp(2.5rem, 6vw, 4rem);
				margin: 0 0 var(--s-1);
				letter-spacing: -0.03em;
			}
			.cat-sub { color: var(--ink-light); font-size: var(--text-base); margin: 0; }
			.empty, .empty-filter { text-align: center; color: var(--ink-medium); padding: var(--s-4) 0; }
			.cat-filters {
				max-width: 760px;
				margin: 0 auto var(--s-2);
				display: flex;
				gap: var(--s-2);
				align-items: center;
				flex-wrap: wrap;
				padding-bottom: var(--s-2);
				border-bottom: 1px solid var(--rule);
			}
			.filter-label {
				font-size: 0.7rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				color: var(--ink-light);
				margin-right: 0.4em;
			}
			.sort-group, .search-group { display: flex; align-items: center; gap: 0.4em; }
			.search-group { flex: 1; min-width: 200px; }
			#sort-select, #search-input {
				font: inherit;
				font-size: 0.85rem;
				padding: 0.35em 0.7em;
				background: var(--paper);
				border: 1px solid var(--rule);
				border-radius: 4px;
				color: var(--ink);
				flex: 1;
				min-width: 0;
			}
			#sort-select:focus, #search-input:focus { outline: none; border-color: var(--cat, var(--brick)); }
			.visible-count {
				font-size: 0.78rem;
				color: var(--ink-light);
				font-weight: 500;
			}
			.list { list-style: none; padding: 0; margin: 0; max-width: 760px; margin: 0 auto; }
			.list li {
				display: grid;
				grid-template-columns: 60px 1fr;
				gap: var(--s-3);
				padding: var(--s-3) 0;
				border-bottom: 1px solid var(--rule);
				align-items: start;
			}
			.list li:first-child { border-top: 1px solid var(--rule); }
			.num {
				font-family: var(--font-display);
				font-size: 1.75rem;
				color: var(--cat, var(--brick));
				font-weight: 700;
				line-height: 1.2;
				font-feature-settings: "tnum";
			}
			.card { text-decoration: none; color: inherit; display: block; }
			.card h2 {
				font-family: var(--font-display);
				font-size: 1.5rem;
				line-height: 1.25;
				margin: 0 0 0.5em;
				letter-spacing: -0.01em;
				color: var(--ink);
				transition: color var(--duration) var(--ease-out);
			}
			.card:hover h2 { color: var(--cat, var(--brick)); }
			.card p {
				font-size: 0.95rem;
				line-height: 1.65;
				color: var(--ink-medium);
				margin: 0 0 0.6em;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.meta {
				font-size: 0.8rem;
				color: var(--ink-light);
				display: flex;
				gap: 0.7em;
				flex-wrap: wrap;
				align-items: center;
			}
			.tag { font-size: 0.75rem; }
			@media (max-width: 720px) {
				.list li { grid-template-columns: 40px 1fr; gap: var(--s-2); }
				.num { font-size: 1.25rem; }
				.card h2 { font-size: 1.2rem; }
			}
		</style>
	</body>
</html>
