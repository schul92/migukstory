---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { CATEGORIES } from '../../content.config';

export async function getStaticPaths() {
	const all = await getCollection('blog');
	return Object.entries(CATEGORIES).map(([key, meta]) => ({
		params: { slug: meta.slug },
		props: {
			catKey: key,
			catMeta: meta,
			posts: all
				.filter(p => p.data.category === key)
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { catMeta, posts } = Astro.props;
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead
			title={`${catMeta.label} — ${SITE_TITLE}`}
			description={`미국 스토리의 ${catMeta.label} 관련 기사 모음. 정부와 주요 언론의 1차 출처를 바탕으로 정리합니다.`}
		/>
	</head>
	<body>
		<Header />
		<main>
			<div class="container">
				<header class="cat-head" style={`--cat: ${catMeta.color}`}>
					<p class="eyebrow">CATEGORY · 카테고리</p>
					<h1>{catMeta.label}</h1>
					<p class="cat-sub">관련 기사 {posts.length}편</p>
				</header>

				{posts.length === 0 ? (
					<p class="empty">아직 이 카테고리의 글이 없습니다. 곧 업데이트됩니다.</p>
				) : (
					<ol class="list">
						{posts.map((post, i) => (
							<li>
								<div class="num">{String(posts.length - i).padStart(2, '0')}</div>
								<a href={`/blog/${post.id}/`} class="card">
									<h2>{post.data.title}</h2>
									<p>{post.data.description}</p>
									<div class="meta">
										<FormattedDate date={post.data.pubDate} />
										{post.data.tags.slice(0, 3).map(t => <span class="tag">#{t}</span>)}
									</div>
								</a>
							</li>
						))}
					</ol>
				)}
			</div>
		</main>
		<Footer />
		<style>
			.cat-head {
				text-align: center;
				padding: var(--s-6) 0 var(--s-3);
				border-bottom: 3px solid var(--cat, var(--ink));
				margin-bottom: var(--s-5);
			}
			.eyebrow { color: var(--cat, var(--brick)) !important; margin: 0 0 var(--s-2); }
			.cat-head h1 {
				font-family: var(--font-display);
				font-size: clamp(2.5rem, 6vw, 4rem);
				margin: 0 0 var(--s-1);
				letter-spacing: -0.03em;
			}
			.cat-sub { color: var(--ink-light); font-size: var(--text-base); margin: 0; }
			.empty { text-align: center; color: var(--ink-medium); padding: var(--s-6) 0; }
			.list { list-style: none; padding: 0; margin: 0; max-width: 760px; margin: 0 auto; }
			.list li {
				display: grid;
				grid-template-columns: 60px 1fr;
				gap: var(--s-3);
				padding: var(--s-3) 0;
				border-bottom: 1px solid var(--rule);
				align-items: start;
			}
			.list li:first-child { border-top: 1px solid var(--rule); }
			.num {
				font-family: var(--font-display);
				font-size: 1.75rem;
				color: var(--cat, var(--brick));
				font-weight: 700;
				line-height: 1.2;
				font-feature-settings: "tnum";
			}
			.card { text-decoration: none; color: inherit; display: block; }
			.card h2 {
				font-family: var(--font-display);
				font-size: 1.5rem;
				line-height: 1.25;
				margin: 0 0 0.5em;
				letter-spacing: -0.01em;
				color: var(--ink);
				transition: color var(--duration) var(--ease-out);
			}
			.card:hover h2 { color: var(--cat, var(--brick)); }
			.card p {
				font-size: 0.95rem;
				line-height: 1.65;
				color: var(--ink-medium);
				margin: 0 0 0.6em;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.meta {
				font-size: 0.8rem;
				color: var(--ink-light);
				display: flex;
				gap: 0.7em;
				flex-wrap: wrap;
				align-items: center;
			}
			.tag { font-size: 0.75rem; }
			@media (max-width: 720px) {
				.list li { grid-template-columns: 40px 1fr; gap: var(--s-2); }
				.num { font-size: 1.25rem; }
				.card h2 { font-size: 1.2rem; }
			}
		</style>
	</body>
</html>
