---
// AdSense placeholder — swap the inner contents with real AdSense code after approval.
// Three preset positions: header, inline (mid-article), footer.
interface Props {
	position?: 'header' | 'inline' | 'footer';
	label?: string;
}
const { position = 'inline', label = '광고' } = Astro.props;
---

<aside class={`ad-slot ad-${position}`} role="complementary" aria-label={label}>
	<span class="ad-label">{label}</span>
	<div class="ad-content">
		<!-- AdSense replace this block after approval:
		<ins class="adsbygoogle"
			style="display:block; width:100%;"
			data-ad-client="ca-pub-XXXXXXXXXX"
			data-ad-slot="XXXXXXXXXX"
			data-ad-format="auto"
			data-full-width-responsive="true"></ins>
		<script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
		-->
		<span class="ad-placeholder">광고 영역 ({position}) · AdSense 승인 후 활성화</span>
	</div>
</aside>

<style>
	.ad-slot {
		max-width: var(--reading-width);
		margin: var(--s-4) auto;
		padding: 0 var(--s-2);
		text-align: center;
	}
	.ad-label {
		display: block;
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--ink-faint);
		font-weight: 600;
		margin-bottom: 0.25em;
	}
	.ad-content {
		min-height: 90px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--paper-soft);
		border: 1px dashed var(--rule);
		border-radius: 4px;
		padding: var(--s-2);
	}
	.ad-placeholder {
		font-size: 0.75rem;
		color: var(--ink-faint);
		letter-spacing: 0.02em;
	}
	.ad-inline { margin: var(--s-5) auto; }
	.ad-header { margin: 0 auto var(--s-3); }
	.ad-footer { margin: var(--s-4) auto var(--s-3); }
</style>
