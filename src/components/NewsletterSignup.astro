---
/**
 * Newsletter signup — Beehiiv embed.
 *
 * Setup (one-time):
 *   1. Create publication at https://beehiiv.com → free tier
 *   2. Settings → Subscribe Forms → Create embed
 *   3. Replace BEEHIIV_PUB_ID below with your publication ID (looks like "pub_abc123...")
 *
 * Until BEEHIIV_PUB_ID is filled in, form gracefully degrades to mailto.
 */

const BEEHIIV_PUB_ID = ''; // TODO: paste publication ID after Beehiiv signup
const action = BEEHIIV_PUB_ID
	? `https://embeds.beehiiv.com/${BEEHIIV_PUB_ID}/subscribe`
	: 'mailto:editor@migukstory.com';
const method = BEEHIIV_PUB_ID ? 'post' : 'get';
---

<form class="newsletter" action={action} method={method} target={BEEHIIV_PUB_ID ? '_blank' : undefined}>
	<div class="newsletter-inner">
		<div class="copy">
			<p class="kicker">무료 가입 선물 · 위클리 뉴스레터</p>
			<h3>「미국 정착 첫 90일 체크리스트」 PDF + 매주 화요일 한 통</h3>
			<p class="sub">
				비자·SSN·은행 계좌·세금·의료보험 — 도착 직후 90일 안에 끝내야 할 모든 것을 한 PDF로.
				<strong>가입 즉시 발송</strong>. 이후 매주 화요일 미국 살이 위클리 뉴스레터.
			</p>
		</div>
		<div class="form-row">
			<label class="sr-only" for="newsletter-email">이메일</label>
			<input
				id="newsletter-email"
				type="email"
				name="email"
				placeholder="email@example.com"
				autocomplete="email"
				required
			/>
			<button type="submit">구독하기</button>
		</div>
		<p class="trust">스팸 없음 · 광고 없음 · 검증된 정보만</p>
	</div>
</form>

<style>
	.newsletter {
		max-width: var(--reading-width);
		margin: var(--s-5) auto;
		padding: var(--s-4) var(--s-3);
		background: var(--paper-soft);
		border-left: 4px solid var(--brick);
		border-radius: 0 6px 6px 0;
	}
	.kicker {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--brick);
		margin: 0 0 0.5em;
	}
	.newsletter h3 {
		font-family: var(--font-display);
		font-size: 1.4rem;
		line-height: 1.3;
		margin: 0 0 0.4em;
		color: var(--ink);
	}
	.newsletter .sub {
		margin: 0 0 var(--s-2);
		color: var(--ink-medium);
		font-size: 0.95rem;
		line-height: 1.6;
	}
	.form-row {
		display: flex;
		gap: 0.5rem;
		margin-top: var(--s-2);
	}
	.form-row input {
		flex: 1;
		min-width: 0;
		padding: 0.7em 1em;
		border: 1px solid var(--rule);
		border-radius: 4px;
		font: inherit;
		font-size: 0.95rem;
		background: var(--paper);
		color: var(--ink);
		transition: border-color var(--duration) var(--ease-out);
	}
	.form-row input:focus {
		outline: none;
		border-color: var(--brick);
	}
	.form-row button {
		padding: 0.7em 1.3em;
		background: var(--brick);
		color: white;
		border: none;
		border-radius: 4px;
		font-weight: 600;
		font-size: 0.95rem;
		cursor: pointer;
		font-family: inherit;
		white-space: nowrap;
		transition: background var(--duration) var(--ease-out);
	}
	.form-row button:hover {
		background: var(--brick-deep);
	}
	.trust {
		margin: var(--s-2) 0 0;
		font-size: 0.78rem;
		color: var(--ink-light);
	}
	@media (max-width: 540px) {
		.form-row { flex-direction: column; }
		.newsletter h3 { font-size: 1.2rem; }
	}
</style>
