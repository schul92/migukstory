---
import { SITE_TITLE, ISSUE_NUMBER } from '../consts';
const today = new Date();
const dateStamp = `${today.getFullYear()}.${String(today.getMonth() + 1).padStart(2, '0')}.${String(today.getDate()).padStart(2, '0')}.`;
---

<header class="masthead">
	<div class="container masthead-inner">
		<div class="meta-left">
			<span class="issue">VOL. 01 · NO. {ISSUE_NUMBER}</span>
		</div>
		<a href="/" class="brand">
			<span class="brand-ko">{SITE_TITLE}</span>
			<span class="brand-en">MIGUK&nbsp;STORY</span>
		</a>
		<div class="meta-right">
			<time class="date" datetime={today.toISOString()}>{dateStamp}</time>
		</div>
	</div>

	<nav class="primary-nav">
		<div class="container nav-inner">
			<a href="/blog">전체 글</a>
			<a href="/blog?age=20-35">20–35세</a>
			<a href="/blog?age=35-55">35–55세</a>
			<a href="/blog?age=55+">55세 이상</a>
			<a href="/about">소개</a>
			<a href="/contact" class="contact-link">문의 · 제보</a>
		</div>
	</nav>
</header>

<style>
	.masthead {
		background: var(--paper);
		border-bottom: 1px solid var(--ink);
		position: relative;
		z-index: 10;
	}
	.masthead-inner {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		padding: var(--s-2) var(--s-3);
		gap: var(--s-3);
	}
	.meta-left, .meta-right {
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: 500;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink-light);
		font-feature-settings: "tnum";
	}
	.meta-right { text-align: right; }
	.brand {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-decoration: none;
		color: var(--ink);
		line-height: 1;
		gap: 0.25rem;
	}
	.brand-ko {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 700;
		letter-spacing: -0.02em;
	}
	.brand-en {
		font-size: 0.6rem;
		font-weight: 500;
		letter-spacing: 0.4em;
		color: var(--brick);
	}

	.primary-nav {
		border-top: 3px double var(--ink);
		background: var(--paper);
	}
	.nav-inner {
		display: flex;
		justify-content: center;
		gap: var(--s-4);
		padding: var(--s-1) var(--s-3);
		flex-wrap: wrap;
	}
	.nav-inner a {
		text-decoration: none;
		color: var(--ink-soft);
		font-size: var(--text-sm);
		font-weight: 500;
		letter-spacing: 0.04em;
		padding: 0.4em 0;
		position: relative;
		transition: color var(--duration) var(--ease-out);
	}
	.nav-inner a::after {
		content: "";
		position: absolute;
		bottom: -2px;
		left: 50%;
		width: 0;
		height: 2px;
		background: var(--brick);
		transition: all var(--duration) var(--ease-out);
		transform: translateX(-50%);
	}
	.nav-inner a:hover {
		color: var(--brick);
	}
	.nav-inner a:hover::after { width: 80%; }
	.contact-link {
		color: var(--brick) !important;
		font-weight: 700;
	}
	.contact-link::before {
		content: "→ ";
		font-weight: 700;
	}

	@media (max-width: 720px) {
		.masthead-inner {
			grid-template-columns: 1fr;
			text-align: center;
			gap: var(--s-1);
		}
		.meta-left, .meta-right { text-align: center; font-size: 0.65rem; }
		.brand-ko { font-size: 1.75rem; }
		.nav-inner { gap: var(--s-2); font-size: 0.8rem; }
	}
</style>
