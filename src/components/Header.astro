---
import { SITE_TITLE, SITE_TAGLINE } from '../consts';
---

<header class="masthead">
	<div class="utility-strip">
		<div class="container utility-inner">
			<a href="mailto:editor@migukstory.com" class="utility-cta">✉ 문의·제보 — editor@migukstory.com</a>
		</div>
	</div>

	<div class="container masthead-inner">
		<div class="meta-left">
			<span class="tagline">{SITE_TAGLINE}</span>
		</div>
		<a href="/" class="brand">
			<span class="brand-ko">{SITE_TITLE}</span>
			<span class="brand-en">MIGUK&nbsp;STORY</span>
		</a>
		<div class="meta-right">
			<a href="/contact" class="contact-pill">문의하기 →</a>
		</div>
	</div>

	<nav class="primary-nav">
		<div class="container nav-inner">
			<a href="/blog">전체 글</a>
			<a href="/category/immigration">이민·비자</a>
			<a href="/category/tax">세금·재테크</a>
			<a href="/category/health">건강·보험</a>
			<a href="/category/education">교육·자녀</a>
			<a href="/category/retirement">은퇴·연금</a>
			<a href="/category/community">한인 커뮤니티</a>
			<a href="/first-30-days">도착 첫 30일</a>
			<a href="/topics">전체 토픽</a>
			<a href="/pros">추천 전문가</a>
			<a href="/contribute">칼럼 기고</a>
			<a href="/search" class="search-link" aria-label="검색">🔍 검색</a>
			<a href="/contact" class="contact-link">문의 · 제보</a>
		</div>
	</nav>
</header>

<style>
	.masthead {
		background: var(--paper);
		border-bottom: 1px solid var(--ink);
		position: relative;
		z-index: 10;
	}
	.masthead-inner {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		padding: var(--s-2) var(--s-3);
		gap: var(--s-3);
	}
	.utility-strip {
		background: var(--ink);
		color: var(--paper);
		padding: 0.45em 0;
		font-size: 0.72rem;
		letter-spacing: 0.04em;
	}
	.utility-inner {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.7em;
		flex-wrap: wrap;
	}
	.utility-cta {
		color: var(--paper);
		text-decoration: none;
		font-weight: 500;
		letter-spacing: 0.04em;
	}
	.utility-cta:hover { color: var(--brick-soft); }
	.tagline {
		font-family: var(--font-body);
		font-size: 0.78rem;
		color: var(--ink-medium);
		letter-spacing: 0;
		text-transform: none;
	}

	.meta-left, .meta-right {
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-light);
		font-feature-settings: "tnum";
	}
	.meta-right { text-align: right; }
	.contact-pill {
		display: inline-block;
		padding: 0.35em 0.8em;
		background: var(--brick);
		color: white !important;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		border-radius: 3px;
		text-decoration: none;
		transition: background var(--duration) var(--ease-out);
	}
	.contact-pill:hover { background: var(--brick-deep); }
	.brand {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-decoration: none;
		color: var(--ink);
		line-height: 1;
		gap: 0.25rem;
	}
	.brand-ko {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 700;
		letter-spacing: -0.02em;
	}
	.brand-en {
		font-size: 0.6rem;
		font-weight: 500;
		letter-spacing: 0.4em;
		color: var(--brick);
	}

	.primary-nav {
		border-top: 3px double var(--ink);
		background: var(--paper);
	}
	.nav-inner {
		display: flex;
		justify-content: center;
		gap: var(--s-4);
		padding: var(--s-1) var(--s-3);
		flex-wrap: wrap;
	}
	.nav-inner a {
		text-decoration: none;
		color: var(--ink-soft);
		font-size: var(--text-sm);
		font-weight: 500;
		letter-spacing: 0.04em;
		padding: 0.4em 0;
		position: relative;
		transition: color var(--duration) var(--ease-out);
	}
	.nav-inner a::after {
		content: "";
		position: absolute;
		bottom: -2px;
		left: 50%;
		width: 0;
		height: 2px;
		background: var(--brick);
		transition: all var(--duration) var(--ease-out);
		transform: translateX(-50%);
	}
	.nav-inner a:hover {
		color: var(--brick);
	}
	.nav-inner a:hover::after { width: 80%; }
	.contact-link {
		color: var(--brick) !important;
		font-weight: 700;
	}
	.contact-link::before {
		content: "→ ";
		font-weight: 700;
	}

	@media (max-width: 720px) {
		/* Mobile slim: utility-strip hidden (CTA lives in nav), brand row tightened,
		   nav becomes horizontal scroll. Target header <120px so H1 lands above fold. */
		.utility-strip { display: none; }
		.masthead-inner {
			grid-template-columns: 1fr auto;
			text-align: left;
			gap: var(--s-2);
			padding: var(--s-1) var(--s-2);
		}
		.meta-left { display: none; }
		.meta-right { text-align: right; font-size: 0.65rem; }
		.brand { align-items: flex-start; }
		.brand-ko { font-size: 1.4rem; line-height: 1; }
		.brand-en { font-size: 0.5rem; letter-spacing: 0.3em; }
		.contact-pill { font-size: 0.65rem; padding: 0.3em 0.6em; }
		.primary-nav { border-top: 1px solid var(--rule); }
		.nav-inner {
			gap: var(--s-2);
			font-size: 0.78rem;
			padding: 0.4em var(--s-2);
			flex-wrap: nowrap;
			overflow-x: auto;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
			justify-content: flex-start;
		}
		.nav-inner::-webkit-scrollbar { display: none; }
		.nav-inner a { white-space: nowrap; padding: 0.25em 0; }
	}
</style>
