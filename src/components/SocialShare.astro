---
/**
 * Social share — icon buttons with hover tooltips.
 *
 * KakaoTalk is the dominant share channel for Korean readers; X (Twitter)
 * and Threads are growing; Facebook is for older demo; Copy Link is the
 * fallback for KakaoTalk Channel / Naver Cafe / 카톡 1:1 share.
 *
 * SVG icons inline so no external deps, no extra requests.
 */

interface Props {
	url: string;
	title: string;
}
const { url, title } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);

const buttons = [
	{
		id: 'kakao',
		label: 'KakaoTalk',
		tooltip: '카카오톡으로 공유',
		href: `https://story.kakao.com/share?url=${encodedUrl}&text=${encodedTitle}`,
	},
	{
		id: 'x',
		label: 'X',
		tooltip: 'X (구 트위터)에 공유',
		href: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
	},
	{
		id: 'threads',
		label: 'Threads',
		tooltip: 'Threads에 공유',
		href: `https://www.threads.net/intent/post?text=${encodedTitle}%20${encodedUrl}`,
	},
	{
		id: 'fb',
		label: 'Facebook',
		tooltip: '페이스북에 공유',
		href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
	},
	{
		id: 'linkedin',
		label: 'LinkedIn',
		tooltip: 'LinkedIn에 공유',
		href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
	},
];
---

<div class="share">
	<span class="share-label">이 글 공유</span>
	<div class="share-buttons">
		{buttons.map((b) => (
			<a
				class={`btn ${b.id}`}
				href={b.href}
				target="_blank"
				rel="noopener nofollow"
				aria-label={b.tooltip}
				data-tooltip={b.tooltip}
			>
				{b.id === 'kakao' && (
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path d="M12 3C6.48 3 2 6.62 2 11.06c0 2.86 1.87 5.37 4.69 6.79l-1.18 4.32c-.1.38.32.69.66.49l5.15-3.39c.23.02.45.03.68.03 5.52 0 10-3.62 10-8.24S17.52 3 12 3z"/>
					</svg>
				)}
				{b.id === 'x' && (
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.451-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644Z"/>
					</svg>
				)}
				{b.id === 'threads' && (
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path d="M17.06 11.13c-.08-.04-.17-.07-.25-.11-.15-2.8-1.68-4.41-4.24-4.42h-.03c-1.53 0-2.81.65-3.59 1.84l1.41.97c.59-.89 1.51-1.08 2.18-1.08h.02c.83 0 1.46.24 1.87.72.3.34.5.82.59 1.42-.69-.12-1.43-.15-2.22-.11-2.24.13-3.69 1.44-3.59 3.26.05.92.51 1.71 1.29 2.23.66.44 1.52.65 2.4.6 1.18-.06 2.1-.51 2.74-1.34.49-.62.8-1.43.94-2.45.59.36.99.83 1.21 1.4.42 1.1.04 2.78-1.16 3.97-1.05 1.04-2.31 1.49-4.21 1.5-2.11-.02-3.7-.69-4.74-2-.97-1.22-1.47-2.99-1.49-5.26.02-2.27.52-4.04 1.49-5.26 1.04-1.31 2.63-1.98 4.74-2 2.12.02 3.74.69 4.81 2.01.53.65.93 1.46 1.18 2.42l1.7-.46c-.3-1.16-.78-2.17-1.42-2.97C16.51 4.05 14.44 3.17 11.96 3.15h-.01c-2.47.02-4.51.9-6.04 2.62C4.5 7.31 3.83 9.41 3.81 11.99v.02c.02 2.58.69 4.68 1.99 6.22 1.54 1.72 3.57 2.6 6.04 2.62h.01c2.2-.02 3.75-.59 5.03-1.86 1.67-1.65 1.62-3.71 1.07-4.99-.39-.91-1.13-1.66-2.13-2.18zm-3.49 3.97c-.97.05-1.98-.38-2.03-1.31-.04-.69.49-1.46 2.08-1.55.18-.01.36-.02.54-.02.58 0 1.12.06 1.61.16-.18 2.24-1.24 2.66-2.2 2.72z"/>
					</svg>
				)}
				{b.id === 'fb' && (
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path d="M24 12.073c0-6.627-5.373-12-12-12S0 5.446 0 12.073c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
					</svg>
				)}
				{b.id === 'linkedin' && (
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
					</svg>
				)}
				<span class="btn-label">{b.label}</span>
			</a>
		))}
		<button
			class="btn copy"
			data-url={url}
			aria-label="링크 복사"
			data-tooltip="링크 복사 (카톡 채널 공유에 사용)"
			type="button"
		>
			<svg viewBox="0 0 24 24" aria-hidden="true">
				<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
				<path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
			</svg>
			<span class="btn-label">링크 복사</span>
		</button>
	</div>
</div>

<script is:inline>
	document.querySelectorAll('.btn.copy').forEach((btn) => {
		btn.addEventListener('click', async () => {
			const url = btn.getAttribute('data-url');
			const label = btn.querySelector('.btn-label');
			if (!label) return;
			try {
				await navigator.clipboard.writeText(url);
				const orig = label.textContent;
				label.textContent = '복사됨 ✓';
				btn.classList.add('copied');
				setTimeout(() => {
					label.textContent = orig;
					btn.classList.remove('copied');
				}, 1500);
			} catch (e) { /* noop */ }
		});
	});
</script>

<style>
	.share {
		max-width: var(--reading-width);
		margin: var(--s-4) auto var(--s-3);
		padding: var(--s-3) var(--s-2);
		display: flex;
		align-items: center;
		gap: var(--s-2);
		flex-wrap: wrap;
		border-top: 1px solid var(--rule);
		border-bottom: 1px solid var(--rule);
	}
	.share-label {
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--ink-light);
		white-space: nowrap;
	}
	.share-buttons {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	.btn {
		--bg: var(--paper);
		--fg: var(--ink);
		--brand: var(--ink);
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		padding: 0;
		font: inherit;
		text-decoration: none;
		color: var(--fg);
		background: var(--bg);
		border: 1px solid var(--rule);
		border-radius: 50%;
		cursor: pointer;
		transition:
			background var(--duration) var(--ease-out),
			color var(--duration) var(--ease-out),
			border-color var(--duration) var(--ease-out),
			transform var(--duration) var(--ease-out);
	}
	.btn svg {
		width: 18px;
		height: 18px;
		fill: currentColor;
		stroke: currentColor;
		stroke-width: 0;
	}
	.btn.copy svg {
		fill: none;
		stroke: currentColor;
		stroke-width: 2;
		stroke-linecap: round;
		stroke-linejoin: round;
	}
	.btn-label {
		position: absolute;
		left: -9999px;
		top: auto;
		width: 1px;
		height: 1px;
		overflow: hidden;
	}

	/* Brand-color hover states */
	.btn:hover { transform: translateY(-2px); }
	.btn.kakao:hover  { --bg:#FEE500; --fg:#3C1E1E; border-color:#FEE500; }
	.btn.x:hover      { --bg:#000;    --fg:#fff;    border-color:#000; }
	.btn.threads:hover{ --bg:#000;    --fg:#fff;    border-color:#000; }
	.btn.fb:hover     { --bg:#1877F2; --fg:#fff;    border-color:#1877F2; }
	.btn.linkedin:hover{ --bg:#0A66C2; --fg:#fff;   border-color:#0A66C2; }
	.btn.copy:hover   { --bg:var(--brick); --fg:#fff; border-color:var(--brick); }
	.btn.copy.copied  { --bg:#16a34a; --fg:#fff; border-color:#16a34a; }

	/* Tooltip on hover (CSS only) */
	.btn::after {
		content: attr(data-tooltip);
		position: absolute;
		bottom: calc(100% + 8px);
		left: 50%;
		transform: translateX(-50%) translateY(4px);
		background: var(--ink);
		color: var(--paper);
		font-size: 0.72rem;
		font-weight: 500;
		padding: 0.35em 0.7em;
		border-radius: 4px;
		white-space: nowrap;
		opacity: 0;
		pointer-events: none;
		transition: all var(--duration) var(--ease-out);
		z-index: 10;
		letter-spacing: 0;
	}
	.btn::before {
		content: "";
		position: absolute;
		bottom: calc(100% + 4px);
		left: 50%;
		transform: translateX(-50%);
		border: 4px solid transparent;
		border-top-color: var(--ink);
		opacity: 0;
		pointer-events: none;
		transition: opacity var(--duration) var(--ease-out);
		z-index: 10;
	}
	.btn:hover::after,
	.btn:focus-visible::after { opacity: 1; transform: translateX(-50%) translateY(0); }
	.btn:hover::before,
	.btn:focus-visible::before { opacity: 1; }

	@media (max-width: 540px) {
		.share { padding: var(--s-2) var(--s-2); }
		.share-buttons { gap: 0.35rem; }
		.btn { width: 38px; height: 38px; }
		.btn svg { width: 16px; height: 16px; }
		/* On touch devices tooltips are unreliable — hide */
		@media (hover: none) { .btn::after, .btn::before { display: none; } }
	}
</style>
