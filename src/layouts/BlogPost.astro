---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import AdSlot from '../components/AdSlot.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import SocialShare from '../components/SocialShare.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { SITE_AUTHOR, SITE_URL } from '../consts';
import { estimateReadingTime } from '../utils/readingTime';

type Props = CollectionEntry<'blog'>['data'] & { entry?: CollectionEntry<'blog'> };

const { title, description, pubDate, updatedDate, heroImage, tags = [], ageGroup, entry } = Astro.props;

const ageLabel =
	ageGroup === '20-35' ? '20–35세' :
	ageGroup === '35-55' ? '35–55세' :
	ageGroup === '55+'   ? '55세 이상' : '전 세대';

// Find this entry for reading time + related posts
const all = await getCollection('blog');
const currentEntry = entry || all.find(p => p.data.title === title);
const readingMinutes = currentEntry ? estimateReadingTime(currentEntry.body || '') : 5;

const shareUrl = new URL(Astro.url.pathname, SITE_URL).toString();
---

<html lang="ko">
	<head>
		<BaseHead
			title={title}
			description={description}
			article={{ pubDate, updatedDate, tags }}
		/>
	</head>

	<body>
		<Header />

		<main>
			<article>

				<!-- ── Article header ───────────────────────────────────────── -->
				<header class="article-head">
					<div class="container">
						<div class="head-rail">
							<span class="age-pill">{ageLabel}</span>
							<span class="rail-sep">·</span>
							<span>{SITE_AUTHOR}</span>
							<span class="rail-sep">·</span>
							<FormattedDate date={pubDate} />
							<span class="rail-sep">·</span>
							<span class="reading-time">⏱ {readingMinutes}분 소요</span>
							{updatedDate && (
								<>
									<span class="rail-sep">·</span>
									<span class="updated">업데이트: <FormattedDate date={updatedDate} /></span>
								</>
							)}
						</div>

						<h1 class="article-title">{title}</h1>

						<p class="article-deck">{description}</p>

						{tags.length > 0 && (
							<div class="header-tags">
								{tags.slice(0, 8).map(t => <span class="tag-chip">#{t}</span>)}
							</div>
						)}
					</div>
				</header>

				{heroImage && (
					<figure class="hero">
						<Image width={1200} height={630} src={heroImage} alt="" />
					</figure>
				)}

				<!-- ── Ad slot: header (above article) ──────────────────────── -->
				<AdSlot position="header" />

				<!-- ── Article body ─────────────────────────────────────────── -->
				<div class="container">
					<div class="prose">
						<slot />
					</div>
				</div>

				<!-- ── Inline newsletter (highest conversion mid-content spot) -->
				<NewsletterSignup />

				<!-- ── Ad slot: inline ──────────────────────────────────────── -->
				<AdSlot position="inline" />

				<!-- ── Social share ─────────────────────────────────────────── -->
				<SocialShare url={shareUrl} title={title} />

				<!-- ── Footer flourish ──────────────────────────────────────── -->
				<div class="container">
					<div class="article-end">
						<span class="end-mark">◆ ◆ ◆</span>
						<p class="end-note">
							이 글은 <strong>미국 스토리</strong> 편집실이 위 출처를 바탕으로 정리한 정보 콘텐츠입니다.
							법률·세무·의료 자문이 아니므로, 구체적 상황은 전문가와 상담하시기 바랍니다.
						</p>
					</div>
				</div>

				<!-- ── Related posts ────────────────────────────────────────── -->
				{currentEntry && <RelatedPosts current={currentEntry} limit={3} />}

				<!-- ── Ad slot: footer ──────────────────────────────────────── -->
				<AdSlot position="footer" />

			</article>
		</main>

		<Footer />

		<style>
			.article-head {
				padding: var(--s-6) 0 var(--s-4);
				text-align: center;
				border-bottom: 1px solid var(--rule);
			}
			.head-rail {
				display: inline-flex;
				gap: 0.5em;
				font-size: var(--text-sm);
				color: var(--ink-light);
				margin-bottom: var(--s-3);
				font-feature-settings: "tnum";
				align-items: center;
				flex-wrap: wrap;
				justify-content: center;
			}
			.age-pill {
				display: inline-block;
				font-size: 0.72rem;
				font-weight: 600;
				padding: 0.18em 0.65em;
				background: var(--ink);
				color: var(--paper);
				letter-spacing: 0.04em;
				border-radius: 2px;
			}
			.rail-sep { color: var(--ink-faint); }
			.updated { color: var(--brick); font-weight: 500; }
			.reading-time { color: var(--ink-medium); font-weight: 500; font-feature-settings: "tnum"; }

			.article-title {
				font-family: var(--font-display);
				font-size: clamp(2.25rem, 5vw, 3.75rem);
				line-height: 1.1;
				margin: 0 auto var(--s-3);
				letter-spacing: -0.03em;
				max-width: 22ch;
				color: var(--ink);
				word-break: keep-all;
			}
			.article-deck {
				font-size: var(--text-lg);
				color: var(--ink-medium);
				line-height: 1.65;
				margin: 0 auto var(--s-3);
				max-width: 36em;
				font-weight: 400;
			}
			.header-tags {
				display: flex;
				gap: 0.6em;
				flex-wrap: wrap;
				justify-content: center;
				margin-top: var(--s-2);
			}
			.tag-chip {
				font-size: 0.75rem;
				color: var(--ink-light);
				background: var(--paper-soft);
				border: 1px solid var(--rule);
				padding: 0.2em 0.7em;
				border-radius: 999px;
				font-weight: 500;
			}

			.hero {
				margin: 0;
				max-width: 1100px;
				margin: 0 auto var(--s-5);
				padding: 0 var(--s-3);
			}
			.hero img {
				width: 100%;
				height: auto;
				border-radius: 4px;
				box-shadow: 0 4px 24px rgba(27, 24, 21, 0.12);
			}

			.prose {
				max-width: var(--reading-width);
				margin: 0 auto;
				padding: var(--s-4) var(--s-2);
			}

			.article-end {
				max-width: var(--reading-width);
				margin: var(--s-5) auto var(--s-6);
				padding: 0 var(--s-2);
				text-align: center;
			}
			.end-mark {
				display: block;
				font-family: var(--font-display);
				color: var(--brick);
				letter-spacing: 0.5em;
				font-size: 1.1rem;
				margin-bottom: var(--s-3);
			}
			.end-note {
				font-size: 0.82rem;
				line-height: 1.7;
				color: var(--ink-light);
				background: var(--paper-soft);
				border-left: 2px solid var(--brick);
				padding: var(--s-2);
				margin: 0;
				text-align: left;
			}
			.end-note strong { color: var(--brick); }

			@media (max-width: 720px) {
				.article-head { padding: var(--s-4) 0 var(--s-3); }
				.head-rail { font-size: 0.78rem; }
				.article-title { font-size: 2rem; line-height: 1.15; }
				.article-deck { font-size: 1rem; }
				.hero { margin-bottom: var(--s-3); padding: 0; }
				.prose { padding: var(--s-3) var(--s-2); }
			}
		</style>
	</body>
</html>
